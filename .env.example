# ── Configuración de Flask ──────────────────────────────────────────────────
# OBLIGATORIO: cambia esto a una cadena aleatoria segura en producción
# Puedes generarla con: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=cambia-esto-por-una-clave-aleatoria-segura

# ── Base de Datos ────────────────────────────────────────────────────────────
# SQLite (desarrollo local - ruta relativa al directorio del proyecto)
DATABASE_URL=sqlite:///data/panaderia.db

# PostgreSQL (producción)
# DATABASE_URL=postgresql://usuario:contraseña@localhost:5432/panaderia

# ── Entorno ──────────────────────────────────────────────────────────────────
FLASK_ENV=production
# FLASK_ENV=development

# ── Sesión ───────────────────────────────────────────────────────────────────
# Tiempo de expiración de sesión en horas (default: 8 horas)
SESSION_LIFETIME_HOURS=8

# ── Seguridad / Login ─────────────────────────────────────────────────────────
# Número máximo de intentos fallidos de login antes de bloqueo temporal
MAX_LOGIN_ATTEMPTS=5
# Tiempo de bloqueo temporal en minutos tras exceder intentos fallidos
LOGIN_LOCKOUT_MINUTES=5

# ── Backups ──────────────────────────────────────────────────────────────────
# Días de retención de backups automáticos
BACKUP_RETENTION_DAYS=30
# Hora del backup automático diario (formato 24h, 0-23)
BACKUP_AUTO_HOUR=23
